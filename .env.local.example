# --- Required ---
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Required for lead capture ---
# Your GoHighLevel inbound webhook URL
# Settings > Integrations > Webhooks (or use a custom workflow webhook trigger)
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-hook-id

# --- Optional ---
# Override the default Calendly link shown on /book
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/30min
